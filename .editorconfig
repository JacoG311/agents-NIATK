root = true

# Minimal, editor-agnostic configuration (no IDE-specific keys)
[*.]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
tab_width = 4
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript / JSON / TypeScript and other web config files: prefer 2-space
[*.{js,jsx,ts,tsx,mjs,cjs,es6,json,jsonc,css,scss,less}]
indent_style = space
indent_size = 2

# HTML and templates
[*.{html,htm,xml,vue}]
indent_style = space
indent_size = 2

# Python files
[*.py]
indent_style = space
indent_size = 4

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Shell scripts
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true

# Markdown and plain text - preserve wrapping/newline behavior
[*.{md,markdown,txt}]
trim_trailing_whitespace = false
insert_final_newline = true
